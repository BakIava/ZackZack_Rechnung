# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI extraction (server-only)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Customer intake model
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Setup document extraction model; falls back to ANTHROPIC_MODEL when omitted
ANTHROPIC_ONBOARDING_MODEL=claude-haiku-4-5-20251001
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Optional: used by Serwist precache revision in CI
# VERCEL_GIT_COMMIT_SHA=

# Suppress Turbopack warning when running `next dev --turbopack` alongside Serwist
# SERWIST_SUPPRESS_TURBOPACK_WARNING=1
